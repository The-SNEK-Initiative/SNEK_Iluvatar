<Window x:Class="DeveloperTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SNEK_Iluvatar Package Builder" Height="900" Width="1000"
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterScreen"
        Background="#F5F5F5" FontFamily="Segoe UI">
    <DockPanel>
        <Rectangle DockPanel.Dock="Top" Height="100" Fill="#0D47A1">
            <Rectangle.Resources>
                <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0D47A1" Offset="0"/>
                    <GradientStop Color="#1565C0" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Resources>
        </Rectangle>
        
        <Grid DockPanel.Dock="Top" Height="100" Background="#0D47A1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image x:Name="LogoImage" Grid.Column="0" Margin="15" Stretch="UniformToFill"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,30,0">
                <TextBlock Text="SNEK Package Builder" FontSize="32" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Create professional installers with compression and encryption" FontSize="12" Foreground="#E3F2FD" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>
        
        <ScrollViewer DockPanel.Dock="Top">
            <Grid Margin="25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,25,0">
                    <Border Background="White" CornerRadius="6" Padding="20" Margin="0,0,0,20" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Package Information" FontSize="14" FontWeight="Bold" Foreground="#0D47A1" Margin="0,0,0,15"/>
                            
                            <TextBlock Text="Package Name *" FontSize="11" FontWeight="Bold" Foreground="#424242" Margin="0,0,0,5"/>
                            <TextBox x:Name="PackageName" Padding="10" Height="36" Background="White" BorderBrush="#BDBDBD" BorderThickness="1" FontSize="11" Margin="0,0,0,15"/>
                            
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Version *" FontSize="11" FontWeight="Bold" Foreground="#424242" Margin="0,0,0,5"/>
                                    <TextBox x:Name="PackageVersion" Padding="10" Height="36" Background="White" BorderBrush="#BDBDBD" BorderThickness="1" FontSize="11" Text="1.0.0" TextAlignment="Left" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Author" FontSize="11" FontWeight="Bold" Foreground="#424242" Margin="0,0,0,5"/>
                                    <TextBox x:Name="PackageAuthor" Padding="10" Height="36" Background="White" BorderBrush="#BDBDBD" BorderThickness="1" FontSize="11" TextAlignment="Left" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="6" Padding="20" Margin="0,0,0,20" BorderBrush="#E0E0E0" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="240"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="Files &amp; Folders" FontSize="14" FontWeight="Bold" Foreground="#0D47A1" Margin="0,0,0,12"/>
                            
                            <ListBox x:Name="FileList" Grid.Row="1" Background="#FAFAFA" BorderBrush="#BDBDBD" BorderThickness="1" Margin="0,0,0,12"/>
                            
                            <UniformGrid Grid.Row="2" Columns="4">
                                <Button Content="+ Add Files" Click="AddFiles_Click" Padding="10,10" Background="#0D47A1" Foreground="White" FontSize="11" FontWeight="Bold" Cursor="Hand" Margin="0,0,8,0"/>
                                <Button Content="+ Add Folder" Click="AddFolder_Click" Padding="10,10" Background="#0D47A1" Foreground="White" FontSize="11" FontWeight="Bold" Cursor="Hand" Margin="0,0,8,0"/>
                                <Button Content="✕ Remove" Click="RemoveFile_Click" Padding="10,10" Background="#E53935" Foreground="White" FontSize="11" FontWeight="Bold" Cursor="Hand" Margin="0,0,8,0"/>
                                <Button Content="Clear All" Click="ClearAll_Click" Padding="10,10" Background="#757575" Foreground="White" FontSize="11" FontWeight="Bold" Cursor="Hand"/>
                            </UniformGrid>
                        </Grid>
                    </Border>

                    <Border Background="White" CornerRadius="6" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Build Settings" FontSize="14" FontWeight="Bold" Foreground="#0D47A1" Margin="0,0,0,15"/>
                            
                            <TextBlock Text="Output Installer Path *" FontSize="11" FontWeight="Bold" Foreground="#424242" Margin="0,0,0,5"/>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="OutputPath" Padding="10" Height="36" Background="#FAFAFA" BorderBrush="#BDBDBD" BorderThickness="1" FontSize="11" IsReadOnly="True" VerticalContentAlignment="Center"/>
                                <Button Content="Browse" Click="Browse_Click" Grid.Column="1" Margin="10,0,0,0" Padding="10" Background="#0D47A1" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                            </Grid>
                            
                            <TextBlock Text="Compression" FontSize="11" FontWeight="Bold" Foreground="#424242" Margin="0,0,0,5"/>
                            <ComboBox x:Name="CompressionComboBox" Padding="10" Height="36" Background="White" BorderBrush="#BDBDBD" BorderThickness="1" FontSize="11" Margin="0,0,0,15" SelectionChanged="CompressionChanged"/>
                            
                            <TextBlock Text="Encryption" FontSize="11" FontWeight="Bold" Foreground="#424242" Margin="0,0,0,5"/>
                            <ComboBox x:Name="EncryptionComboBox" Padding="10" Height="36" Background="White" BorderBrush="#BDBDBD" BorderThickness="1" FontSize="11" SelectionChanged="EncryptionChanged"/>
                            
                            <TextBlock Text="Installation Options" FontSize="11" FontWeight="Bold" Foreground="#424242" Margin="0,15,0,5"/>
                            <StackPanel>
                                <CheckBox x:Name="StartMenuOption" Content="Add to Start Menu (Default)" IsChecked="True" FontSize="11" Checked="StartMenu_Checked" Unchecked="StartMenu_Checked" Margin="0,0,0,5"/>
                                <CheckBox x:Name="PathOption" Content="Add to System PATH" IsChecked="False" FontSize="11" Checked="Path_Checked" Unchecked="Path_Checked"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,0,0">
                    <Border Background="#0D47A1" CornerRadius="6" Padding="18" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Package Summary" FontSize="12" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                            
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Files" FontSize="10" Foreground="#B3E5FC" FontWeight="Bold"/>
                                <TextBlock x:Name="FileCountText" Text="0" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,3,0,0"/>
                            </StackPanel>
                            
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Total Size" FontSize="10" Foreground="#B3E5FC" FontWeight="Bold"/>
                                <TextBlock x:Name="TotalSizeText" Text="0 KB" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,3,0,0"/>
                            </StackPanel>
                            
                            <Border Background="#1565C0" CornerRadius="4" Padding="10" Margin="0,10,0,10">
                                <StackPanel>
                                    <TextBlock Text="Compression" FontSize="10" Foreground="#B3E5FC" FontWeight="Bold"/>
                                    <TextBlock x:Name="CompressionText" Text="None" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="#1565C0" CornerRadius="4" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Encryption" FontSize="10" Foreground="#B3E5FC" FontWeight="Bold"/>
                                    <TextBlock x:Name="EncryptionText" Text="None" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <Button x:Name="BuildButton" Content="⚡ BUILD INSTALLER" Click="Build_Click" 
                            Padding="15,14" Background="#2ECC71" Foreground="White" 
                            FontSize="13" FontWeight="Bold" Height="50" 
                            BorderThickness="0" Cursor="Hand" Margin="0,0,0,12" ToolTip="Create the installer package"/>

                    <Border Background="#FFF9C4" CornerRadius="4" Padding="10" BorderBrush="#FBC02D" BorderThickness="1" Margin="0,0,0,10">
                        <TextBlock x:Name="StatusText" Text="Ready to build" Foreground="#F57F17" FontSize="10" TextWrapping="Wrap" LineHeight="14"/>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
        
        <ProgressBar DockPanel.Dock="Bottom" x:Name="ProgressBar" Height="3" IsIndeterminate="False" Background="#E0E0E0" Foreground="#2ECC71"/>
    </DockPanel>
</Window>
